<script type="application/ld+json">{"@context":"https:\/\/schema.org\/","@graph":[{"@context":"https:\/\/schema.org\/","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"item":{"name":"Home","@id":"https:\/\/kumpoovietnam.com"}},{"@type":"ListItem","position":2,"item":{"name":"V\u1ee3t cho ng\u01b0\u1eddi m\u1edbi","@id":"https:\/\/kumpoovietnam.com\/danh-muc-san-pham\/vot-cho-nguoi-moi\/"}},{"@type":"ListItem","position":3,"item":{"name":"V\u1ee3t c\u1ea7u l\u00f4ng Kumpoo K520 Pro ch\u00ednh h\u00e3ng","@id":"https:\/\/kumpoovietnam.com\/san-pham\/vot-cau-long-kumpoo-k520-pro-chinh-hang\/"}}]},{"@context":"https:\/\/schema.org\/","@type":"Product","@id":"https:\/\/kumpoovietnam.com\/san-pham\/vot-cau-long-kumpoo-k520-pro-chinh-hang\/#product","name":"V\u1ee3t c\u1ea7u l\u00f4ng Kumpoo K520 Pro ch\u00ednh h\u00e3ng","url":"https:\/\/kumpoovietnam.com\/san-pham\/vot-cau-long-kumpoo-k520-pro-chinh-hang\/","description":"Si\u00eau ph\u1ea9m Kumpoo Power Control K520 Pro l\u00e0 s\u1ef1 l\u1ef1a ch\u1ecdn h\u00e0ng \u0111\u1ea7u khi b\u1ea1n \u0111ang t\u00ecm ki\u1ebfm cho m\u00ecnh v\u1ee3t c\u1ea7u l\u00f4ng gi\u00e1 r\u1ebb n\u1ed5i tr\u1ed9i v\u1edbi thi\u1ebft k\u1ebf \u0111\u1eb9p, hi\u1ec7n \u0111\u1ea1i\r\n&amp;nbsp;\r\nQU\u00c0 T\u1eb6NG\r\n- 1 c\u01b0\u1edbc ch\u00ednh h\u00e3ng Kumpoo K65 ho\u1eb7c VS BG7 (C\u0102NG S\u1eb4N 10.5KG)\r\n- 1 qu\u1ea5n c\u00e1n ch\u00ednh h\u00e3ng Kumpoo (M\u00e0u ng\u1eabu nhi\u00ean)\r\n- 1 bao n\u1ec9 \u0111\u1ef1ng v\u1ee3t\r\n&amp;nbsp;\r\nL\u01afU \u00dd\r\n- Shop g\u1eedi nguy\u00ean set, cu\u1ed1n c\u00e1n kh\u00f4ng qu\u1ea5n s\u1eb5n\r\n- Shop kh\u00f4ng nh\u1eadn c\u0103ng qu\u00e1 12kg. N\u1ebfu b\u1ea1n mu\u1ed1n c\u0103ng \u226512kg, vui l\u00f2ng c\u0103ng m\u00e1y \u0111i\u1ec7n t\u1eed t\u1ea1i c\u1eeda h\u00e0ng th\u1ec3 thao c\u1ea7u l\u00f4ng g\u1ea7n b\u1ea1n, note ho\u1eb7c nh\u1eafn shop g\u1eedi khung v\u1ee3t v\u00e0 t\u1eb7ng c\u01b0\u1edbc cho b\u1ea1n \u1ea1\r\n- 1 \u0110\u1ed4I 1 TRONG 30 NG\u00c0Y: \u0110\u1ed1i v\u1edbi khung v\u1ee3t, trong tr\u01b0\u1eddng h\u1ee3p l\u1ed7i, h\u1ecfng, s\u1eadp khung do l\u1ed7i nsx\r\n&amp;nbsp;\r\nTH\u00d4NG S\u1ed0 K\u1ef8 THU\u1eacT\r\n- Th\u01b0\u01a1ng hi\u1ec7u: Kumpoo\r\n\r\n- M\u00e3 s\u1ea3n ph\u1ea9m: Power Control K520 Pro\r\n\r\n- M\u00e0u s\u1eafc: \u0110en, Tr\u1eafng\r\n\r\n- C\u01b0\u1edbc v\u1ee3t: C\u0103ng s\u1eb5n (Ch\u1ecdn m\u00e0u)\r\n\r\n- \u0110\u1ed9 c\u1ee9ng: 8.5 - Trung b\u00ecnh\r\n\r\n- Ch\u1ea5t li\u1ec7u: Carbon Graphite (Than ch\u00ec carbon)\r\n\r\n- Tr\u1ecdng l\u01b0\u1ee3ng: 82 \u00b1 2 g (4U)\r\n\r\n- Chi\u1ec1u d\u00e0i v\u1ee3t: 675 mm\r\n\r\n- S\u1ee9c c\u0103ng d\u00e2y: Max 30LBS ~ 13.6kg\r\n\r\n- \u0110i\u1ec3m c\u00e2n b\u1eb1ng: 295 \u00b1 5 mm\r\n\r\n&amp;nbsp;\r\nC\u00d4NG NGH\u1ec6 V\u1ee2T KUMPOO K520 PRO\r\n- Ch\u1ea5t li\u1ec7u High Modulus Graphite + Nano Carbon Control Power t\u0103ng \u0111\u1ed9 b\u1ec1n l\u00ean 20%, tr\u1ecdng l\u01b0\u1ee3ng nh\u1eb9, t\u1ea1o c\u1ea3m gi\u00e1c \u0111\u00e1nh \u00eam \u00e1i v\u1edbi m\u1ed9t ch\u00fat \u0111\u1ed9 rung, linh ho\u1ea1t ki\u1ec3m so\u00e1t t\u1ed1t\r\n\r\n- \u0110i\u1ec3m c\u00e2n b\u1eb1ng trung b\u00ecnh 295mm: Tr\u1ecdng l\u01b0\u1ee3ng \u0111\u01b0\u1ee3c ph\u00e2n b\u1ed1 \u0111\u1ec1u tr\u00ean to\u00e0n b\u1ed9 v\u1ee3t, c\u00e2n b\u1eb1ng gi\u1eefa t\u1ea5n c\u00f4ng v\u00e0 ph\u00f2ng th\u1ee7. V\u1ee3t linh ho\u1ea1t v\u00e0 d\u1ec5 \u0111i\u1ec1u khi\u1ec3n, th\u00edch h\u1ee3p ng\u01b0\u1eddi ch\u01a1i c\u00f3 l\u1ed1i \u0111\u00e1nh \u0111a d\u1ea1ng, th\u00edch s\u1ef1 c\u00e2n b\u1eb1ng gi\u1eefa smash v\u00e0 ki\u1ec3m so\u00e1t l\u01b0\u1edbi, ho\u1eb7c ng\u01b0\u1eddi ch\u01a1i to\u00e0n di\u1ec7n.\r\n\r\n- \u0110\u1ed9 c\u1ee9ng \u0111\u0169a 8.5mm (C\u1ee9ng trung b\u00ecnh): C\u00e2n b\u1eb1ng gi\u1eefa \u0111\u1ed9 c\u1ee9ng v\u00e0 s\u1ef1 linh ho\u1ea1t, cho ph\u00e9p k\u1ebft h\u1ee3p gi\u1eefa s\u1ee9c m\u1ea1nh v\u00e0 ki\u1ec3m so\u00e1t. Ph\u00f9 h\u1ee3p v\u1edbi nhi\u1ec1u t\u00ecnh hu\u1ed1ng thi \u0111\u1ea5u, phong c\u00e1ch ch\u01a1i c\u1ea7u, t\u1eeb t\u1ea5n c\u00f4ng \u0111\u1ebfn ph\u00f2ng th\u1ee7.\r\n\r\n- S\u1ee9c c\u0103ng d\u00e2y t\u1ed1i \u0111a l\u00ean \u0111\u1ebfn 30lbs ~13.6kg: Khung v\u1ee3t ti\u00eau chu\u1ea9n v\u1edbi \u0111\u1ed9 c\u1ee9ng v\u1eeba ph\u1ea3i v\u00e0 n\u1ed5i b\u1eadt v\u1ec1 s\u1ef1 \u0111\u00e0n h\u1ed3i tr\u1ee3 l\u1ef1c, ph\u00f9 h\u1ee3p v\u1edbi m\u1ecdi ng\u01b0\u1eddi ch\u01a1i t\u1eeb b\u1eaft \u0111\u1ea7u \u0111\u1ebfn chuy\u00ean nghi\u1ec7p.\r\n\r\n&amp;nbsp;\r\n\u0110\u1ed0I T\u01af\u1ee2NG PH\u00d9 H\u1ee2P\r\n- L\u1ed1i ch\u01a1i to\u00e0n di\u1ec7n, thi\u00ean v\u1ec1 \u0111i\u1ec1u c\u1ea7u n\u1ed5i tr\u1ed9i v\u1edbi nh\u1eefng qu\u1ea3 ph\u00f4ng c\u1ea7u cao s\u00e2u \u0111i \u0111\u1ebfn cu\u1ed1i s\u00e2n v\u00e0 lu\u00f4n c\u00e1n v\u1ea1ch \u0111\u00edch\r\n- D\u00f9ng trong c\u1ea3 \u0111\u00e1nh \u0111\u01a1n v\u00e0 \u0111\u00e1nh \u0111\u00f4i\r\n- D\u00e0nh cho ng\u01b0\u1eddi ch\u01a1i c\u00f3 tr\u00ecnh \u0111\u1ed9 trung b\u00ecnh, trung b\u00ecnh - y\u1ebfu v\u00e0 c\u1ea3 nh\u1eefng b\u1ea1n m\u1edbi t\u1eadp","image":"https:\/\/kumpoovietnam.com\/wp-content\/uploads\/2025\/01\/Untitled-16546488855.jpg","sku":"K520PRO","offers":[{"@type":"Offer","price":"500000","priceValidUntil":"2027-12-31","priceSpecification":{"price":"500000","priceCurrency":"VND","valueAddedTaxIncluded":"false"},"priceCurrency":"VND","availability":"http:\/\/schema.org\/InStock","url":"https:\/\/kumpoovietnam.com\/san-pham\/vot-cau-long-kumpoo-k520-pro-chinh-hang\/","seller":{"@type":"Organization","name":"Kumpoo Store","url":"https:\/\/kumpoovietnam.com"}}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.64","reviewCount":11},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","bestRating":"5","ratingValue":"5","worstRating":"1"},"author":{"@type":"Person","name":"Gia Khang"},"reviewBody":"V\u1ec1 H\u1ed3 Ch\u00ed Minh kho\u1ea3ng bao l\u00e2u shop","datePublished":"2024-12-26T17:55:57+07:00"},{"@type":"Review","reviewRating":{"@type":"Rating","bestRating":"5","ratingValue":"5","worstRating":"1"},"author":{"@type":"Person","name":"Gia Khang"},"reviewBody":"giao \u0111\u1ebfn H\u1ed3 Ch\u00ed Minh kho\u1ea3ng bao ng\u00e0y \u1ea1?","datePublished":"2024-12-22T21:34:58+07:00"},{"@type":"Review","reviewRating":{"@type":"Rating","bestRating":"5","ratingValue":"5","worstRating":"1"},"author":{"@type":"Person","name":"D\u1ea5u t\u00ean"},"reviewBody":"\u0111\u00e2y l\u00e0 ch\u00ednh h\u00e3ng \u1ea1","datePublished":"2024-12-06T19:16:05+07:00"},{"@type":"Review","reviewRating":{"@type":"Rating","bestRating":"5","ratingValue":"1","worstRating":"1"},"author":{"@type":"Person","name":"H\u00f9ng"},"reviewBody":"N\u1ebfu c\u00f3 th\u00ec \u0111an cho e t\u1ea7m 10k\u00ed \u1ea1","datePublished":"2024-11-20T18:38:44+07:00"},{"@type":"Review","reviewRating":{"@type":"Rating","bestRating":"5","ratingValue":"5","worstRating":"1"},"author":{"@type":"Person","name":"H\u00f9ng"},"reviewBody":"C\u00f3 ki\u1ec3u l\u00e0m l\u01b0\u1edbi s\u1eb5n trong v\u1ee3t ko \u1ea1","datePublished":"2024-11-20T18:37:21+07:00"}]}]}</script>
